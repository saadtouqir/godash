# GoDash Backend Environment Template
# Copy this file to a new file named '.env' and fill in the values.

# The connection string for your MongoDB Atlas cluster
MONGO_URI=your_mongodb_connection_string_here

# Port for the Express server to run on
# (Port 5001 is used to avoid macOS system conflicts on Port 5000)
# Or use any PORT as you prefer, just make sure to update the frontend proxy settings if you change it from 5001.
PORT=5001

# JWT Secret Key: Used by jsonwebtoken to sign and verify user session tokens.
# SECURITY NOTE: Never share this key or commit it to a public repository.
# If this key is compromised, an attacker could forge user login tokens.
JWT_SECRET=your_random_secret_here
